cd $NYLAROOT/build/sources/libxcrypt*
make clean || echo already clean

./autogen.sh
./configure --prefix=/usr                 \
            --enable-hashes=strong,glibc  \
            --enable-obsolete-api=no      \
            --disable-static              \
            --disable-failure-tokens      \
            --disable-werror

make
make DESTDIR=$DESTDIR install
